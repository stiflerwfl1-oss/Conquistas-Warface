DISCORD_TOKEN=seu_token_do_bot_aqui

# Opcional: IDs dos canais permitidos separados por virgula.
# Se vazio, o bot responde em todos os canais onde tiver permissao.
DISCORD_ALLOWED_CHANNEL_IDS=

# Atualizacao automatica dos desafios em minutos
DATA_REFRESH_MINUTES=10

# Formato recomendado: URL raw do data.js no GitHub
GITHUB_DATA_URL=https://raw.githubusercontent.com/stiflerwfl1-oss/Conquistas-Warface/main/data.js

# Alternativa: montar URL por partes (se GITHUB_DATA_URL estiver vazio)
GITHUB_OWNER=stiflerwfl1-oss
GITHUB_REPO=Conquistas-Warface
GITHUB_BRANCH=main
GITHUB_DATA_PATH=data.js
